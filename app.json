{
  "expo": {
    "name": "ShopMyRoom",
    "slug": "shopmyroom",
    "scheme": "shopmyroom",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "platforms": [
      "ios"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.yourname.shopmyroom",
      "infoPlist": {
        "NSPhotoLibraryUsageDescription": "We need access to your photos to redesign your room.",
        "NSCameraUsageDescription": "Take a photo of your room to get started.",
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "plugins": [
      "expo-router",
      "expo-image-picker"
    ],
    "extra": {
      "router": {},
      "eas": {
        "projectId": "4e16f312-fb40-4b46-a848-7b616f16ec2d"
      }
    }
  }
}
